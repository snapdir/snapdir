snapdir_gcs_store_get_push_command() {
	# Gets the command for syncing the contents of the staging directory
	# to Google Cloud Storage.
	# The staging directory is a temporary directory that is used sync
	# the contents of a specific manifest to the gcs bucket.
	# We rely on 'gcloud storage' to do the actual push and integrity
	# check.
	#
	#     snapdir-gcs-store get-push-command \
	#         --staging-dir "${staging_directory}" \
	#         --store "${store}"
	#
	set -eEuo pipefail
	local id="${_SNAPDIR_GCS_STORE_ID:?Missing --id}"
	local store="${_SNAPDIR_GCS_STORE_STORE:?Missing --store}"
	local source_dir="${_SNAPDIR_GCS_STORE_STAGING_DIR:?Missing --staging-dir}"
	local manifest_rel_path
	manifest_rel_path=$(_snapdir_get_manifest_rel_path "${id}")
	# remove trailing slash
	source_dir="${source_dir%/}"

	local remote_manifest_path="${store%/}/${manifest_rel_path#/}"
	# remove leading slash
	remote_manifest_path="${remote_manifest_path#/}"

	# only push when the manifest does not exist
	# first push objects then the manifest
	cat <<-EOF
		set -eEuo pipefail;
		_existing_manifest=\$(${_SNAPDIR_GCS_STORE_BIN_PATH} get-manifest --id "${id}" --store "${store}" --retries 0 2>&1 | head -1 || echo "");
		if [[ \$_existing_manifest =~ ^D.*/ ]]; then
			echo "Manifest already exists, skipping push";
		else
			SECONDS=0
			# Make sure the objects directory exists in the staging directory
			mkdir -p "${source_dir%/}/.objects/"
			# Create an empty marker file to ensure the directory is not empty
			touch "${source_dir%/}/.objects/.empty-marker"
			# Sync objects.
			# Notes:
			# - The local source path must NOT have a trailing slash -
			#   'gcloud storage rsync' (>=5.x) errors with "Did not find existing
			#   container" when a trailing slash is present on a local source.
			# - snapdir stages objects as symlinks into the cache; rsync ignores
			#   symlinks by default, so --no-ignore-symlinks is required to upload
			#   the content they point to (equivalent to 'aws s3 sync --follow-symlinks').
			# - --recursive is required because objects are nested under sharded dirs.
			gcloud storage rsync --quiet --recursive --no-ignore-symlinks "${source_dir%/}/.objects" "${store%/}/.objects/";
			# Make sure the manifests directory exists
			mkdir -p "$(dirname "${source_dir%/}/${manifest_rel_path#/}")";
			# Copy manifest
			gcloud storage cp --quiet "${source_dir%/}/${manifest_rel_path#/}" "$remote_manifest_path";
			echo "Done pushing ${id} after \$SECONDS seconds";
		fi
	EOF
}

