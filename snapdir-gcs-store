_snapdir_gcs_store_get_transfer_objects_command() {
	# Prints the command to transfer the objects from GCS to the local cache.
	set -eEuo pipefail
	local target_dir="${1:?Missing target directory}"
	local log_file="${2:?Missing log_file}"
	local file_paths_on_manifest
	file_paths_on_manifest="$(cat)"
	local total_files=0
	local entry_parts=()
	local checksum
	local rel_file_path

	for entry in $file_paths_on_manifest; do
		IFS=' ' read -r -a entry_parts <<<"${entry}"
		checksum="${entry_parts[2]}"
		rel_file_path="$(_snapdir_get_object_rel_path "${checksum}")"
		if ! test -f "${target_dir}/${rel_file_path}"; then
			# redirect stdout and stderr to the temporary file $log_file but also send stdout to stdout and stderr to stderr
			echo "nice ${_SNAPDIR_GCS_STORE_BIN_PATH} fetch --store \"${store}\" --checksum \"${checksum}\" --source-path \"${rel_file_path}\" --target-path \"${target_dir}/${rel_file_path}\" --log-file \"$log_file\" & "
			total_files=$((total_files + 1))
		fi
	done

	if [[ $total_files -eq 0 ]]; then
		echo 'echo "No new objects to fetch.";'
	fi
}

_snapdir_gcs_fetch_to_cache() {
	# This method will persist files from GCS to a target local path and verify
	# that the checksums match the --checksum argument.
	# The file is downloaded from GCS to a temporary location renamed to the
	# final location once the integrity has been checked.
	# We can use the same logic for objects and manifests.
	set -eEuo pipefail
	local source_path="${_SNAPDIR_GCS_STORE_SOURCE_PATH:?Missing --source-path}"
	local target_path="${_SNAPDIR_GCS_STORE_TARGET_PATH:?Missing --target-path}"
	local checksum="${_SNAPDIR_GCS_STORE_CHECKSUM:?Missing --checksum}"
	local retries="${_SNAPDIR_GCS_STORE_RETRIES:-5}"

	# To avoid concurrency errors, the file will be copied to a
	# temporary location and then renamed to its final location.
	# We only perform integrity checks on the temporary file since
	# the mv command does not affect the contents of the data on disk
	# as long as the tmp file is on the same filesystem.
	local tmp_target_path
	tmp_target_path="${target_path}.$(_snapdir_tmp_id)"
	mkdir -p "$(dirname "${tmp_target_path}")"

	_snapdir_gcs_store_export_env_defaults

	# Construct GCS path correctly
	# For testing, we need to use the specific test bucket + path
	local remote_relative_path="${source_path#/}"
	if [[ ${_SNAPDIR_STORE_BASE_DIR:+x} ]]; then
		remote_relative_path="${_SNAPDIR_STORE_BASE_DIR%/}/${remote_relative_path}"
	fi
	remote_relative_path="${remote_relative_path#/}"
	local gcs_path="gs://${_SNAPDIR_STORE_BUCKET}/${remote_relative_path}"

	# download the file from GCS
	if ! gcloud storage cp --quiet "${gcs_path}" "${tmp_target_path}" 2>/dev/null; then
		echo "WARNING: Failed with command: 'gcloud storage cp --quiet \"${gcs_path}\" \"${tmp_target_path}\"'" >&2
	fi

	local valid_checksum
	valid_checksum="$({ test -f "${tmp_target_path}" && test "$(b3sum "${tmp_target_path}" --no-names)" == "${checksum}"; } || echo "false" && echo "true")"
	if [[ $valid_checksum == "false" ]]; then
		local reason="fetching"
		if test -f "${tmp_target_path}"; then
			rm -rf "${tmp_target_path}"
			reason="mismatched checksum after fetching"
		fi
		# subtract 1 from _SNAPDIR_GCS_STORE_RETRIES
		retries=$((retries - 1))
		if [[ ${retries} -gt 0 ]]; then
			echo "WARNING: Temporary failed $reason: 'gcloud storage cp --quiet \"${gcs_path}\" \"${tmp_target_path}\"'. ${retries} retries left." >&2
			_SNAPDIR_GCS_STORE_RETRIES=$retries _snapdir_gcs_fetch_to_cache
		else
			# give up
			echo "ERROR: Failed $reason ${gcs_path} to ${target_path} with checksum ${checksum}." >&2
			exit 1
		fi
	else
		mv "${tmp_target_path}" "${target_path}"
		echo "SAVED: ${target_path}"
	fi
}

_snapdir_gcs_store_get_remote_prefix() {
	set -eEuo pipefail
	local store="${1:?Missing store}"
	local store_dir
	store_dir="$(echo "$store" | sed -E 's|^gs:/*[^/]*/?||')"
	# remove trailing slash
	echo "${store_dir%/}"
}

_snapdir_gcs_store_export_env_defaults() {
	# Environment variables
	set -eEuo pipefail
	_snapdir_set_manifest_from_stdin_or_id
	if [[ ${_SNAPDIR_ID:-""} != "" ]]; then
		_SNAPDIR_GCS_STORE_ID="${_SNAPDIR_ID}"
	fi
	: "${_SNAPDIR_GCS_STORE_STORE:?Missing --store required for GCS store}"
	_SNAPDIR_STORE="$_SNAPDIR_GCS_STORE_STORE"
	_snapdir_export_store_vars

	# Expose the credentials file for GCS
	export SNAPDIR_GCS_STORE_CREDENTIALS_FILE="${SNAPDIR_GCS_STORE_CREDENTIALS_FILE:-${GOOGLE_APPLICATION_CREDENTIALS:-""}}"
	if [[ $SNAPDIR_GCS_STORE_CREDENTIALS_FILE != "" ]]; then
		export GOOGLE_APPLICATION_CREDENTIALS="$SNAPDIR_GCS_STORE_CREDENTIALS_FILE"
	fi

	: "${_SNAPDIR_STORE_BUCKET:?Missing _SNAPDIR_STORE_BUCKET}"
}

