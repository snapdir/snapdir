{
  "name": "@snapdir/snapdir",
  "version": "1.11.0",
  "description": "Node.js binding for snapdir — content-addressable directory snapshots.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/snapdir/snapdir.git",
    "directory": "bindings/node"
  },
  "homepage": "https://snapdir.org",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js",
      "types": "./index.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.mjs",
    "index.d.ts",
    "*.node",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "napi": {
    "binaryName": "snapdir",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release --no-js && node scripts/gen-wrapper.cjs",
    "test": "vitest run",
    "lint": "eslint ."
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
