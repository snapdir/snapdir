{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@snapdir/snapdir": ["./index.d.ts"]
    }
  },
  "include": ["test/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
